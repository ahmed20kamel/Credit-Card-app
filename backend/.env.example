# ============================================
# CardVault Backend - Environment Variables
# ============================================

# Django Settings
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# ============================================
# Database Configuration
# ============================================
# For LOCAL DEVELOPMENT (SQLite - Default):
USE_SQLITE=True
POSTGRES_HOST=localhost

# For LOCAL DEVELOPMENT (PostgreSQL):
# USE_SQLITE=False
# POSTGRES_HOST=localhost
# POSTGRES_DB=cardvault
# POSTGRES_USER=cardvault
# POSTGRES_PASSWORD=cardvault_dev_pass
# POSTGRES_PORT=5432

# For DOCKER (PostgreSQL):
# USE_SQLITE=False
# POSTGRES_HOST=db
# POSTGRES_DB=cardvault
# POSTGRES_USER=cardvault
# POSTGRES_PASSWORD=cardvault_dev_pass
# POSTGRES_PORT=5432

# ============================================
# CORS Settings
# ============================================
CORS_ORIGINS=http://localhost:3000

# ============================================
# Security Keys (CHANGE IN PRODUCTION!)
# ============================================
ENCRYPTION_KEY=CHANGE-ME-32-byte-key-for-aes256
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-64

# ============================================
# Optional Settings
# ============================================
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEFAULT_ADMIN_EMAIL=admin@cardvault.com
DEFAULT_ADMIN_PASSWORD=admin123
